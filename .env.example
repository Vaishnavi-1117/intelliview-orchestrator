# Copy this file to .env and customize for your environment.

# --- Service discovery ---
# In docker-compose, services are reachable as `redis` / `postgres` on the
# default bridge network. In local dev, point these at localhost.
REDIS_URL=redis://localhost:6379/0
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_interview_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Worker / Celery ---
WORKER_CONCURRENCY=4
MAX_RETRIES=3
WORKER_ID=worker-1

# --- API / Security ---
# Token required for worker management endpoints. CHANGE THIS in production.
API_TOKEN=dev-token-change-me
# Comma-separated origin list for CORS, or * for dev only.
CORS_ALLOW_ORIGINS=*

# --- Request validation ---
# Max request body size in bytes (default: 1 MB)
MAX_REQUEST_BODY_BYTES=1048576

# --- Audit logging ---
# Path to audit log file. Leave empty for stdout-only logging.
AUDIT_LOG_FILE=

# --- Monitoring ---
# Enable Prometheus metrics endpoint at /metrics
ENABLE_PROMETHEUS=true
# Grafana admin password (change in production)
GRAFANA_PASSWORD=admin

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Structured JSON logging: 1=enabled, 0=disabled
JSON_LOGGING=1
